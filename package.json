{
  "name": "myq-garage-worker",
  "version": "0.1.9",
  "description": "Cloudflare Worker that parses myQ garage door notification emails and serves a live status dashboard",
  "author": "Andrew Tryder",
  "license": "MIT",
  "homepage": "https://github.com/andrewtryder/myq-garage-worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewtryder/myq-garage-worker.git"
  },
  "bugs": {
    "url": "https://github.com/andrewtryder/myq-garage-worker/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev",
    "deploy": "wrangler deploy --minify --tag v$(node -p \"require('./package.json').version\") --message \"Local deployment of v$(node -p \"require('./package.json').version\")\"",
    "types": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:email": "node scripts/send-test-email.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.4.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,jsonc}": [
      "prettier --write"
    ]
  }
}
